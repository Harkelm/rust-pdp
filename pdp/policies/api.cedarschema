namespace ApiGateway {
  entity Role;

  entity User in [Role] {
      email: String,
      department?: String,
  };

  entity ApiResource;

  action "read" appliesTo {
      principal: [User],
      resource: [ApiResource],
  };

  action "write" appliesTo {
      principal: [User],
      resource: [ApiResource],
  };

  action "delete" appliesTo {
      principal: [User],
      resource: [ApiResource],
  };
}
